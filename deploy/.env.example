# ----- Required -----

# Cookie signing key. MUST be at least 32 bytes of random data. Generate:
#   openssl rand -base64 48
EMBER_SESSION_KEY=replace-me-with-32+-bytes-of-random-data-replace-me

# First-run admin credentials. Used only when the users table is empty.
EMBER_ADMIN_USER=admin
EMBER_ADMIN_PASSWORD=change-me-immediately

# ----- Caddy -----

# The hostname Caddy listens on. Use a real DNS name for automatic Let's Encrypt
# certs; use `localhost` for local development; or set `tls internal` in the
# Caddyfile for self-signed homelab certs.
EMBER_HOSTNAME=localhost
CADDY_EMAIL=admin@example.com

# ----- Optional knobs -----

EMBER_OLLAMA_MODEL=qwen2.5:1.5b
EMBER_FRESH_WINDOW=6h
EMBER_POLL_CONCURRENCY=8
EMBER_POLL_TICK=60s
EMBER_LOG_LEVEL=info
