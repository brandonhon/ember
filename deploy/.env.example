# ----- Required -----

# Cookie signing key. MUST be at least 32 bytes of random data. Generate:
#   openssl rand -base64 48
EMBER_SESSION_KEY=replace-me-with-32+-bytes-of-random-data-replace-me

# First-run admin credentials. Used only when the users table is empty.
# Password must be at least 8 characters or the app exits on startup.
EMBER_ADMIN_USER=admin
EMBER_ADMIN_PASSWORD=change-me-immediately

# ----- Caddy / TLS -----

# Hostname Caddy listens on.
#   - Real DNS name (e.g. ember.example.com) + CADDY_EMAIL + ports 80/443
#     publicly reachable → Caddy auto-fetches a Let's Encrypt cert.
#   - `localhost` or any unresolvable name → Caddy uses a local self-signed
#     cert (browsers will warn). For a homelab cert trusted by your own
#     machines, set `tls internal` in deploy/Caddyfile.
EMBER_HOSTNAME=localhost

# Email registered with Let's Encrypt for ACME notifications (expiry, etc.).
# Required only when actually getting LE certs (real hostname above).
CADDY_EMAIL=admin@example.com

# Host ports the Caddy container publishes to. Override when 80/443 are taken
# on the host (e.g. another reverse-proxy already runs there). Caddy still
# listens on 80/443 *inside* the container. Reach the site at the mapped
# host port — for HTTP_PORT=8080 / HTTPS_PORT=8443: https://localhost:8443.
# Letting Caddy issue Let's Encrypt certs requires public reachability on
# standard 80 (HTTP-01) or 443 (TLS-ALPN); for homelab/dev set `tls internal`
# in the Caddyfile and any ports are fine.
EMBER_HTTP_PORT=80
EMBER_HTTPS_PORT=443

# 80 → 443 redirect. Caddy redirects HTTP to HTTPS by default for every site
# with managed TLS. Set this to `1` (or any non-empty value) to disable the
# redirect — useful when Ember is fronted by another reverse proxy that
# already terminates TLS. Leave commented / empty to keep the redirect on.
# EMBER_DISABLE_HTTPS_REDIRECT=1

# ----- Optional knobs -----

EMBER_FRESH_WINDOW=6h
EMBER_POLL_CONCURRENCY=8
EMBER_POLL_TICK=60s
EMBER_LOG_LEVEL=info
